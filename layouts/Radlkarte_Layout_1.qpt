 <LayoutItem referencePoint="0" marginX="0" frame="false" size="88.5718,31.2196,mm" templateUuid="{944ebdc6-bfe8-40b6-9622-b28fc2f89d4a}" valign="32" uuid="{944ebdc6-bfe8-40b6-9622-b28fc2f89d4a}" opacity="1" htmlState="0" type="65641" position="55.0049,493.121,mm" positionLock="false" id="" itemRotation="270" halign="1" blendMode="0" visibility="1" positionOnPage="55.0049,493.121,mm" excludeFromExports="0" labelText="badvoeslau@radlobby.at  ·  badvoeslau.radlobby.at&#xa;&#xa;Die Radlobby Bad Vöslau ist eine Gruppe des Vereines Radlobby Niederösterreich. Wir fördern die umweltfreundliche Mobilität und vertreten die Interessen der Radfahrenden und zu Fuß Gehenden in Bad Vöslau und Umgebung.&#xa;&#xa;Unterstütze unsere Arbeit für sicherer Radwege und Fußwege, und werde Mitglied bei der Radlobby!" zValue="15" background="false" groupUuid="" outlineWidthM="0.3,mm" marginY="0" frameJoinStyle="miter">
